# Backend API origin used by the frontend build and websocket client.
# Example: https://your-backend.railway.app
VITE_API_BACKEND_URL=http://localhost:8080

# Optional override for the API path. Defaults to /api/v1.
VITE_API_BASE_URL=/api/v1

# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
VITE_GOOGLE_AUTH_URL=
GEMINI_API_KEY=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"

# VITE_ALLOWED_HOSTS: Comma-separated list of hosts allowed to access the dev server (e.g. localhost, .ngrok-free.app)
VITE_ALLOWED_HOSTS=
